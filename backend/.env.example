# The Colony — Backend Environment Variables
# Copy this file to .env and fill in at least one AI API key.

# ── AI API Keys (at least one required for live agents) ──
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here
GEMINI_API_KEY=your-gemini-key-here

# ── Optional: Model overrides ──
# DEFAULT_MODEL=claude-3-5-sonnet-20241022

# ── Optional: Quality threshold (0-100, default 50) ──
# QUALITY_FLAG_THRESHOLD=50
